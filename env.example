# ┌─────────────────────────────────────────────────────────────┐
# │ Elastic Stack Configuration                                 │
# │ Copy to .env: cp env.example .env                           │
# │                                                             │
# │ Resource defaults sized for macOS Apple Silicon with         │
# │ constrained RAM (e.g., M3 Pro 18GB running 3 UTM VMs).     │
# │ Increase ES_MEM_LIMIT and KB_MEM_LIMIT on larger hosts.    │
# │                                                             │
# │ HOST_IP must be reachable from Elastic Agents on guests.    │
# │ For local UTM lab: HOST_IP=192.168.56.1                    │
# └─────────────────────────────────────────────────────────────┘
STACK_VERSION=9.3.1
CLUSTER_NAME=elastic
LICENSE=basic
ES_MEM_LIMIT=2g
ES_PORT=9200
ES_CPU_LIMIT=2
KIBANA_PORT=5601
KB_MEM_LIMIT=1g
ENCRYPTION_KEY=WjccOVnjlNtZvKmG7EmJQKYO5j5IF1Le2/6Z3rYCEik=
ELASTIC_PASSWORD=f0YjoPbrkN0=
KIBANA_PASSWORD=f0YjoPbrkN0=
HOST_IP=172.16.5.100
FLEET_PORT=8220
